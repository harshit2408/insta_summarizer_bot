# =============================================
# Instagram Learning Agent - Environment Config
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Download Settings ─────────────────────────
# Local directory where reels/images will be saved
DOWNLOAD_DIR=./downloads

# Max file size to download in MB (0 = unlimited)
MAX_FILE_SIZE_MB=100

# ── Scraper Settings ──────────────────────────
# Timeout in seconds for HTTP requests
REQUEST_TIMEOUT_SECONDS=30

# Number of retry attempts for yt-dlp before falling back to GraphQL
YTDLP_MAX_RETRIES=2

# ── Telegram Bot (Phase 2) ────────────────────
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── AWS (Phase 2) ─────────────────────────────
# AWS_REGION=us-east-1
# DYNAMODB_USERS_TABLE=LearningAgent-Users
# DYNAMODB_REELS_TABLE=LearningAgent-ProcessedReels
# S3_BUCKET_NAME=learning-agent-content

# ── AI APIs (Phase 2) ─────────────────────────
# GROQ_API_KEY=your_groq_api_key_here
